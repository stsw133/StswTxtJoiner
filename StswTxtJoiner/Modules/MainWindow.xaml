<se:StswWindow x:Class="StswTxtJoiner.MainWindow"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:StswTxtJoiner"
               xmlns:se="clr-namespace:StswExpress.Wpf;assembly=StswExpress.Wpf"
               mc:Ignorable="d" d:DataContext="{d:DesignInstance local:MainContext}"
               Height="600" Width="1000" WindowStartupLocation="CenterScreen"
               Title="{x:Static se:StswFnUI.AppNameAndVersion}" Icon="/Resources/icon.ico">
	<se:StswWindow.DataContext>
		<local:MainContext/>
	</se:StswWindow.DataContext>

	<se:StswWindow.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
	</se:StswWindow.Resources>

	<Grid Margin="0 1 0 0">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" MinWidth="10"/>
			<ColumnDefinition Width="1"/>
			<ColumnDefinition Width="*" MinWidth="10"/>
		</Grid.ColumnDefinitions>

		<se:StswSeparator Grid.ColumnSpan="3" BorderThickness="1" Margin="0 -1 0 0" VerticalAlignment="Top"/>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="*" MinHeight="10"/>
				<RowDefinition Height="1"/>
				<RowDefinition Height="150"/>
			</Grid.RowDefinitions>

			<!-- file list -->
			<se:StswGroupBox se:StswControl.IsBorderless="True" Padding="0" SeparatorThickness="1">
				<se:StswGroupBox.Header>
					<DockPanel Margin="3">
						<se:StswSubButton DockPanel.Dock="Right" Command="{Binding ConvertFilesCommand}" IconData="{x:Static se:StswIcons.Play}" IconFill="{DynamicResource StswColor.Modify}"/>
						<se:StswSubButton DockPanel.Dock="Right" Command="{Binding AddFilesCommand}" IconData="{x:Static se:StswIcons.Plus}" IconFill="{DynamicResource StswColor.Positive}"/>
						<se:StswSubButton DockPanel.Dock="Right" Command="{Binding ClearFilesCommand}" IconData="{x:Static se:StswIcons.Broom}" IconFill="{DynamicResource StswColor.Negative}"/>
						<se:StswSubDrop DockPanel.Dock="Right" IconData="{x:Static se:StswIcons.Filter}" IconFill="{DynamicResource StswColor.Neutral}">
							<StackPanel Margin="3" Orientation="Horizontal">
								<se:StswRadioBox Content="Only" IconScale="0.75" IsChecked="{Binding IsOnlyFilterMode}" Margin="3"/>
								<se:StswRadioBox Content="Excluded" IconScale="0.75" IsChecked="{Binding IsExcludedFilterMode}" Margin="3"/>
							</StackPanel>
							<se:StswSeparator BorderThickness="1"/>
							<se:StswTextBox se:StswControl.IsBorderless="True"
											AcceptsReturn="True"
											ScrollViewer.VerticalScrollBarVisibility="Auto"
											Text="{Binding OnlyFilterExtensions}"
											Visibility="{Binding IsOnlyFilterMode}"
											VerticalContentAlignment="Top"
											Height="50" Width="150"/>
							<se:StswTextBox se:StswControl.IsBorderless="True"
											AcceptsReturn="True"
											ScrollViewer.VerticalScrollBarVisibility="Auto"
											Text="{Binding ExcludedFilterExtensions}"
											Visibility="{Binding IsExcludedFilterMode}"
											VerticalContentAlignment="Top"
											Height="50" Width="150"/>
						</se:StswSubDrop>
						<se:StswLabel Content="{Binding FileListHeader}" IconData="{x:Static se:StswIcons.File}"/>
					</DockPanel>
				</se:StswGroupBox.Header>

				<se:StswDragBox se:StswControl.IsBorderless="True"
								AllowDrop="True"
								ItemsSource="{Binding FileList}"
								SelectedItem="{Binding SelectedFileInfo}"
								SelectedValuePath="FilePath"
								Drop="{se:StswEventToCommand Command=DropFilesCommand, PassEventArgs=True}"
								KeyDown="{se:StswEventToCommand Command=ClearFileCommand, CommandParameterBinding={Binding SelectedFileInfo}, AllowedKey=Delete}"
								PreviewDragOver="{se:StswEventToCommand Command=DragFilesOverCommand, PassEventArgs=True}">
					<se:StswDragBox.ItemTemplate>
						<DataTemplate>
							<se:StswLabel Content="{Binding FileName}" IconSource="{Binding FilePath, Converter={x:Static se:StswPathToIconConverter.Instance}}"/>
						</DataTemplate>
					</se:StswDragBox.ItemTemplate>
				</se:StswDragBox>
			</se:StswGroupBox>

			<se:StswGridSplitter Grid.Row="1" Background="{DynamicResource StswBorder.Static.Border}" ResizeDirection="Rows"/>

			<!-- separator -->
			<se:StswGroupBox Grid.Row="2" se:StswControl.IsBorderless="True" Padding="0" SeparatorThickness="1">
				<se:StswGroupBox.Header>
					<DockPanel Margin="3">
						<se:StswSubButton DockPanel.Dock="Right" Command="{Binding ClearSeparatorCommand}" IconData="{x:Static se:StswIcons.Broom}" IconFill="{DynamicResource StswColor.Negative}"/>
						<se:StswSubDrop DockPanel.Dock="Right" IconData="{x:Static se:StswIcons.Filter}" IconFill="{DynamicResource StswColor.Neutral}">
							<StackPanel Margin="6">
								<se:StswLabel Content="{}{fileName} - file name"/>
								<se:StswLabel Content="{}{fileNo} - file number"/>
							</StackPanel>
						</se:StswSubDrop>
						<se:StswSubCheck DockPanel.Dock="Right" IsChecked="{Binding IsSeparatorBeforeFile}" IconChecked="{x:Static se:StswIcons.CheckboxMarkedOutline}" IconUnchecked="{x:Static se:StswIcons.CheckboxBlankOutline}"/>
						<se:StswLabel Content="{Binding SeparatorHeader}" IconData="{x:Static se:StswIcons.ArrowSplitHorizontal}"/>
					</DockPanel>
				</se:StswGroupBox.Header>

				<se:StswTextBox se:StswControl.IsBorderless="True"
								AcceptsReturn="True" AcceptsTab="True"
								Text="{Binding SeparatorText}"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Stretch"
								VerticalAlignment="Stretch"
								VerticalContentAlignment="Stretch"
								ScrollViewer.VerticalScrollBarVisibility="Auto"/>
			</se:StswGroupBox>
		</Grid>

		<se:StswGridSplitter Grid.Column="1" Background="{DynamicResource StswBorder.Static.Border}" ResizeDirection="Columns"/>

		<!-- output -->
		<se:StswGroupBox Grid.Column="2" se:StswControl.IsBorderless="True" Padding="0" SeparatorThickness="1">
			<se:StswGroupBox.Header>
				<DockPanel Margin="3">
					<se:StswSubButton DockPanel.Dock="Right" Command="{Binding SaveOutputCommand}" IconData="{x:Static se:StswIcons.ContentSave}" IconFill="{DynamicResource StswColor.Modify}"/>
					<se:StswSubButton DockPanel.Dock="Right" Command="{Binding CopyOutputCommand}" IconData="{x:Static se:StswIcons.ContentCopy}" IconFill="{DynamicResource StswColor.Neutral}"/>
					<se:StswSubCheck DockPanel.Dock="Right" IsChecked="{Binding IsOutputReadOnly}" IconChecked="{x:Static se:StswIcons.CheckboxBlankOutline}" IconUnchecked="{x:Static se:StswIcons.CheckboxMarkedOutline}"/>
					<se:StswSubDrop DockPanel.Dock="Right" IconData="{x:Static se:StswIcons.Filter}" IconFill="{DynamicResource StswColor.Neutral}">
						<StackPanel Margin="6">
							<se:StswLabel Content="Output preview character limit"/>
							<se:StswTextBox Width="150" Text="{Binding OutputPreviewCharacterLimit}"/>
						</StackPanel>
					</se:StswSubDrop>
					<se:StswLabel Content="{Binding OutputHeader}" IconData="{x:Static se:StswIcons.Console}"/>
				</DockPanel>
			</se:StswGroupBox.Header>

			<Grid>
				<se:StswTextBox se:StswControl.IsBorderless="True"
								AcceptsReturn="True" AcceptsTab="True"
								IsReadOnly="{Binding IsOutputReadOnly}"
								Text="{Binding OutputPreviewText}"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Stretch"
								VerticalAlignment="Stretch"
								VerticalContentAlignment="Stretch"
								ScrollViewer.VerticalScrollBarVisibility="Auto"
								Visibility="{Binding IsOutputTextVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
				<se:StswLabel Content="Output too large to view"
							  HorizontalAlignment="Center"
							  VerticalAlignment="Center"
							  Visibility="{Binding IsOutputTooLarge, Converter={StaticResource BoolToVisibilityConverter}}"/>
			</Grid>
		</se:StswGroupBox>
	</Grid>
</se:StswWindow>
