<se:StswWindow x:Class="StswTxtJoiner.MainWindow"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:StswTxtJoiner"
               xmlns:se="clr-namespace:StswExpress.Wpf;assembly=StswExpress.Wpf"
               mc:Ignorable="d" d:DataContext="{d:DesignInstance local:MainContext}"
               Height="600" Width="1000" WindowStartupLocation="CenterScreen"
               Title="{x:Static se:StswFnUI.AppNameAndVersion}" Icon="/Resources/icon.ico">
	<se:StswWindow.DataContext>
		<local:MainContext/>
	</se:StswWindow.DataContext>

	<DockPanel>
		<se:StswSeparator DockPanel.Dock="Top" BorderThickness="1"/>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="1"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<DockPanel>
				<se:StswTextBox DockPanel.Dock="Bottom"
								AcceptsReturn="True" AcceptsTab="True"
								BorderThickness="1"
								Height="100"
								Margin="5"
								Text="{Binding SeparatorText}"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Stretch"
								VerticalAlignment="Stretch"
								VerticalContentAlignment="Stretch"/>
				<se:StswLabel DockPanel.Dock="Bottom" Content="Separator:" IconData="{x:Static se:StswIcons.ArrowSplitHorizontal}" IconScale="1.25" Margin="5 5 5 -5"/>
				<Grid>
					<se:StswDragBox BorderThickness="0 0 0 1"
									DisplayMemberPath="FileName"
									ItemsSource="{Binding FileList}"
									SelectedItem="{Binding SelectedFileInfo}"
									SelectedValuePath="FilePath"
									KeyDown="{se:StswEventToCommand Command=ClearFileCommand, CommandParameterBinding={Binding SelectedFileInfo}, AllowedKey=Delete}"/>
					<StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
						<se:StswSubButton Command="{Binding AddFilesCommand}" IconData="{x:Static se:StswIcons.FilePlus}" IconFill="{DynamicResource StswColor.Positive}"/>
						<se:StswSubButton Command="{Binding ClearFilesCommand}" IconData="{x:Static se:StswIcons.Broom}" IconFill="{DynamicResource StswColor.Negative}"/>
						<se:StswSubButton Command="{Binding ConvertFilesCommand}" IconData="{x:Static se:StswIcons.Play}" IconFill="{DynamicResource StswColor.Modify}"/>
					</StackPanel>
				</Grid>
			</DockPanel>
			<se:StswGridSplitter Grid.Column="1" Background="{DynamicResource StswBorder.Static.Border}" ResizeDirection="Columns"/>
			<se:StswTextBox Grid.Column="2" se:StswControl.IsBorderless="True"
							AcceptsReturn="True" AcceptsTab="True"
							Text="{Binding OutputText}"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch"
							VerticalAlignment="Stretch"
							VerticalContentAlignment="Stretch"/>
		</Grid>
	</DockPanel>
</se:StswWindow>
